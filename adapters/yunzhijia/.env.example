# Intent Broker 配置
BROKER_URL=http://127.0.0.1:4318

# 云之家机器人 Webhook URL
# 格式：https://www.yunzhijia.com/gateway/robot/webhook/send?yzjtype=0&yzjtoken=YOUR_TOKEN
YZJ_SEND_URL="https://www.yunzhijia.com/gateway/robot/webhook/send?yzjtype=0&yzjtoken=YOUR_TOKEN"

# 云之家 App API（可选）
# 配置后 adapter 会优先使用 App API 发送文本、图片和文件；YZJ_SEND_URL 仍可作为旧 webhook 降级通道。
YZJ_APP_ID="YOUR_APP_ID"
YZJ_APP_SECRET="YOUR_APP_SECRET"
YZJ_ENDPOINT="https://www.yunzhijia.com"

# away/channel 模式下使用 App API 发送到默认群时配置。
YZJ_GROUP_ID="YOUR_GROUP_ID"
